<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/white"
    tools:context=".features.Admin.activities.UploadSongScreenActivity"
    >

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/top_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        >

        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:contentDescription="@string/back_button"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />
    </RelativeLayout>

    <!-- Bottom Navigation Bar -->
    <RelativeLayout
        android:id="@+id/bottom_nav_layout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bottom_nav_background"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/nav_person_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/person_icon"
                    android:padding="8dp"
                    android:src="@drawable/ic_person" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_add_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/add_icon"
                    android:padding="8dp"
                    android:src="@drawable/ic_add_circle" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_music_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:background="@drawable/music_note_selected_background"
                    android:contentDescription="@string/music_icon"
                    android:padding="8dp"
                    app:tint="@color/white"
                    android:src="@drawable/ic_music_note" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_group_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/group_icon"
                    android:padding="8dp"
                    android:src="@drawable/medical_assistance" />
            </FrameLayout>
        </LinearLayout>
    </RelativeLayout>


    <!-- Main Content -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_above="@id/bottom_nav_layout"
        android:layout_below="@id/top_bar_layout"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:id="@+id/song_upload_container"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:background="@drawable/scrollview_border_background"
            android:padding="16dp">

            <!-- Upload Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/rounded_background_pink"
                android:padding="24dp">

                <TextView
                    android:id="@+id/upload_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="32dp"
                    android:text="@string/upload_new_song"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Song Name Row -->
                <RelativeLayout
                    android:id="@+id/song_name_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/upload_title"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/song_name_label"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/song_name"
                        android:textColor="@android:color/black"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/song_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_toEndOf="@id/song_name_label"
                        android:background="@drawable/rounded_edittext_background"
                        android:hint="@string/song_name_hint"
                        android:inputType="text"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </RelativeLayout>

                <!-- Song Upload Row -->
                <RelativeLayout
                    android:id="@+id/song_upload_row"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_below="@id/song_name_row"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/song_upload_label"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/song_upload"
                        android:textColor="@android:color/black"
                        android:textSize="16sp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/song_upload_label">

                        <TextView
                            android:id="@+id/song_upload_input"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/rounded_edittext_background"
                            android:paddingStart="16dp"
                            android:maxLines="1"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:textSize="12sp"
                            android:paddingEnd="56dp" />

                        <ImageButton
                            android:id="@+id/upload_icon_button"
                            android:layout_width="45dp"
                            android:layout_height="55dp"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/rounded_button_dark"
                            android:src="@drawable/ic_upload_cloud"
                            android:contentDescription="@string/upload_button"
                            />
                    </RelativeLayout>

                    <!--Image-->

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/image_upload_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/song_upload_row"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/image_upload_label"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/consultant_image"
                        android:textColor="@android:color/black"
                        android:textSize="16sp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/image_upload_label">

                        <TextView
                            android:id="@+id/image_upload_input"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:gravity="center_vertical"
                            android:ellipsize="end"
                            android:background="@drawable/rounded_edittext_background"
                            android:paddingStart="16dp"
                            android:paddingEnd="56dp" />

                        <ImageButton
                            android:id="@+id/upload_icon_image_button"
                            android:layout_width="45dp"
                            android:layout_height="49dp"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/rounded_button_dark"
                            android:src="@drawable/ic_upload_cloud"
                            android:contentDescription="@string/upload_button"
                            />
                    </RelativeLayout>
                </RelativeLayout>


                <!-- Category Row -->
                <RelativeLayout
                    android:id="@+id/category_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/image_upload_row"
                    android:layout_marginBottom="40dp">

                    <TextView
                        android:id="@+id/category_label"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/category"
                        android:textColor="@android:color/black"
                        android:textSize="16sp" />

                    <!-- Wrapper to hold both Spinner and Arrow -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_toEndOf="@id/category_label"
                        android:background="@drawable/rounded_edittext_background">

                        <Spinner
                            android:id="@+id/category_spinner"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingStart="16dp"
                            android:paddingEnd="40dp" /> <!-- Add padding to prevent text from overlapping arrow -->

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="16dp"
                            android:src="@drawable/ic_arrow_down"
                            android:clickable="false"
                            android:focusable="false"
                            app:tint="#888888"
                            />

                    </RelativeLayout>
                </RelativeLayout>

                <Button
                    android:id="@+id/upload_button"
                    android:layout_width="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_height="56dp"
                    android:paddingLeft="30dp"
                    android:paddingRight="30dp"
                    android:layout_below="@id/category_row"
                    android:background="@drawable/rounded_button_dark"
                    app:backgroundTint="@null"
                    android:text="@string/upload"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />

            </RelativeLayout>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
