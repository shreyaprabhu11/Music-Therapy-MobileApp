<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_background_pink"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:id="@+id/item_user_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_user_placeholder"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:contentDescription="User Icon"/>

    <LinearLayout
        android:id="@+id/user_details_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/item_user_icon"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/item_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name Surname"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/item_user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USERID01"
            android:textColor="#666666"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/item_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Karnataka"
            android:textColor="#666666"
            android:textSize="14sp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/item_stage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stage:I"
        android:textStyle="bold"
        android:textColor="#333333"
        android:textSize="16sp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="8dp"
        />

</RelativeLayout>

