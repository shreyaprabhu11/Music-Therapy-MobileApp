<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:background="@android:color/white"
    android:descendantFocusability="blocksDescendants"
    >

    <!-- First Row: Name and Email -->
    <RelativeLayout
        android:id="@+id/first_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name Surname"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:background="@drawable/rounded_background_grey_heading"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/user_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/user_name"
            android:layout_marginStart="8dp"
            android:text="abc@example.com"
            android:textColorLink="@color/black"
            android:textStyle="bold"
            android:background="@drawable/rounded_background_grey_heading"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:autoLink="email"
            />

    </RelativeLayout>

    <!-- Second Row: Message and Time -->
    <RelativeLayout
        android:id="@+id/second_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/first_row">

        <TextView
            android:id="@+id/message_snippet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/timestamp"
            android:text="I've been using this music app for a few week..."
            android:textColor="@android:color/white"
            android:background="@drawable/rounded_background_grey"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:text="12:00pm"
            android:textColor="@android:color/white"
            android:background="@drawable/rounded_background_grey"
            android:padding="8dp"/>

    </RelativeLayout>

</RelativeLayout>

