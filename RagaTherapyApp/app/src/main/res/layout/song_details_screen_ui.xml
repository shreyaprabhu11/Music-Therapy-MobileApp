<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/white"
    android:id="@+id/main"
    tools:context=".features.Admin.activities.SongDetailsScreenUIActivity">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/top_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize">

        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:contentDescription="@string/back_button"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />
    </RelativeLayout>

    <!-- Bottom Navigation Bar -->
    <RelativeLayout
        android:id="@+id/bottom_nav_layout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bottom_nav_background"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/nav_person_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/person_icon"
                    android:padding="8dp"
                    android:src="@drawable/ic_person" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_add_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/add_icon"
                    android:padding="8dp"
                    android:src="@drawable/ic_add_circle" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_music_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:background="@drawable/music_note_selected_background"
                    android:contentDescription="@string/music_icon"
                    android:padding="8dp"
                    app:tint="@color/white"
                    android:src="@drawable/ic_music_note" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_group_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/group_icon"
                    android:padding="8dp"
                    android:src="@drawable/medical_assistance" />
            </FrameLayout>
        </LinearLayout>
    </RelativeLayout>

    <!-- Area Chart Card -->
    <RelativeLayout
        android:id="@+id/chart_cards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_bar_layout"
        android:padding="16dp">

        <TextView
            android:id="@+id/chart_titles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/songs_contribution"
            android:textColor="@android:color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Area chart (using LineChart view) -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/areaCharts"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_below="@id/chart_titles"/>

    </RelativeLayout>

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/song_details_fragment_containers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/chart_cards"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_above="@id/bottom_nav_layout"
        android:background="@drawable/background_curved_top"
        tools:layout="@layout/song_details_fragment_layout"
        android:layout_marginTop="40dp"
        android:layout_gravity="center"/>

</RelativeLayout>
