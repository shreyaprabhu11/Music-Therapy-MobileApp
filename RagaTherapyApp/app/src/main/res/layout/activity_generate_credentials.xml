<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:id="@+id/main"
    tools:context=".features.Admin.activities.GenerateCredentialsActivity">

    <ImageView
        android:id="@+id/profile_image"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_user_placeholder"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="78dp"
        android:elevation="10dp"
        android:contentDescription="@string/profile_image" />

    <RelativeLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/profile_image"
        android:layout_marginTop="40dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/scrollview_border_background"
        android:padding="24dp">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_centerHorizontal="true"
            android:text="@string/generated_credentials_title"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="52dp"/>

        <RelativeLayout
            android:id="@+id/role_layout"
            android:layout_below="@id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/role_label"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Username"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/email_input"
                android:layout_width="250dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/role_label"
                android:autofillHints="name"
                android:text="USER1001"
                android:textStyle="bold"
                android:background="@drawable/rounded_edittext_background"
                android:inputType="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </RelativeLayout>

        <!-- Full Name Row -->
        <RelativeLayout
            android:id="@+id/full_name_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/role_layout"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/full_name_label"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Password"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/disease_input"
                android:layout_width="250dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/full_name_label"
                android:autofillHints="name"
                android:textStyle="bold"
                android:text="pwd1234!@"
                android:background="@drawable/rounded_edittext_background"
                android:inputType="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </RelativeLayout>

        <Button
            android:id="@+id/copy_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/full_name_layout"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="48dp"
            android:backgroundTint="#6A1B4D"
            android:text="@string/copy_button_text"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            tools:targetApi="lollipop" />

    </RelativeLayout>

</RelativeLayout>