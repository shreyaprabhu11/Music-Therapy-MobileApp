<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".features.Admin.activities.ListViewClickActivity">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/top_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FCE4EC">

        <!-- Your icons and other content -->
        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/back_button"
            android:padding="8dp"
            android:layout_centerVertical="true"/>

        <ImageView
            android:id="@+id/chart_icon"
            android:layout_width="48dp"
            android:layout_marginStart="10dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_pie_chart"
            android:contentDescription="@string/notifications_icon" />

        <ImageView
            android:id="@+id/person_icon_top"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_toStartOf="@id/chart_icon"
            android:layout_centerVertical="true"
            android:padding="8dp"
            app:tint="@color/white"
            android:background="@drawable/chosen"
            android:src="@drawable/ic_person_icon_top"
            android:contentDescription="@string/person_icon" />

        <!-- Bottom border overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_alignParentBottom="true"
            android:background="#000000"/>

    </RelativeLayout>

    <!-- User Details Section -->
    <RelativeLayout
        android:id="@+id/user_details_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_below="@id/top_bar_layout"
        >

        <ImageView
            android:id="@+id/profile_image"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_user_placeholder"
            android:layout_alignParentEnd="true"
            android:contentDescription="@string/profile_image"/>

        <LinearLayout
            android:id="@+id/user_info_texts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/profile_image"
            android:layout_marginEnd="16dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_background_pink"
                android:padding="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/name_Surname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/user_name_details"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_alignParentTop="true" />

                <TextView
                    android:id="@+id/user_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User-ID: 123"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_below="@id/name_Surname"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="4dp" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_background_pink"
                android:padding="8dp">

                <TextView
                    android:id="@+id/phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone: +91 9876543210"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_alignParentTop="true" />

                <TextView
                    android:id="@+id/email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email: user@example.com"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_below="@id/phone"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="4dp" />

            </RelativeLayout>

        </LinearLayout>
    </RelativeLayout>

    <!-- Disease and Stage Info -->
    <RelativeLayout
        android:id="@+id/disease_info_section"
        android:layout_width="match_parent"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="16dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/user_details_section"
        android:background="@drawable/rounded_background_pink"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/disease_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_info"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_alignParentStart="true"/>

        <TextView
            android:id="@+id/stage_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stage_info"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>

    <!-- Listening Time -->
    <TextView
        android:id="@+id/listening_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_below="@id/disease_info_section"
        android:background="@drawable/rounded_background_pink"
        android:padding="12dp"
        android:textStyle="bold"
        android:text="@string/listening_time_info"
        android:textColor="#333"
        android:layout_marginBottom="24dp"/>

    <!-- Assigned Consultants Title -->
    <TextView
        android:id="@+id/consultants_title"
        android:layout_width="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/listening_time"
        android:text="@string/assigned_consultants"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <ListView
        android:id="@+id/consultants_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/consultants_title"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:divider="@null"
        android:dividerHeight="7dp"
        tools:listitem="@layout/list_item_consultant"/>

    <!-- Bottom Navigation Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:elevation="4dp">
        <!-- Using a LinearLayout for easy distribution -->
        <RelativeLayout
            android:id="@+id/bottom_nav_layout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/ic_navigation"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/nav_person_button"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/person_icon"
                        android:padding="8dp"
                        android:background="@drawable/music_note_selected_background"
                        app:tint="@color/white"
                        android:src="@drawable/ic_person" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/nav_add_button"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/add_icon"
                        android:padding="8dp"
                        android:src="@drawable/ic_add_circle" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/nav_music_button"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/music_icon"
                        android:padding="8dp"
                        android:src="@drawable/ic_music_note" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/nav_group_button"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/group_icon"
                        android:padding="8dp"
                        android:src="@drawable/medical_assistance" />
                </FrameLayout>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>


</RelativeLayout>


