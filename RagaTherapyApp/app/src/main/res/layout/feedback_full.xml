<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="@android:color/white"
    tools:context=".features.Admin.activities.FeedbackFullActivity">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/top_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:padding="8dp">

        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/back_button"
            android:padding="8dp"
            android:layout_centerVertical="true"/>

    </RelativeLayout>

    <!-- Scrollable Message Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/top_bar_layout"
        android:layout_above="@id/bottom_nav_layout"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Sender Info Bubble -->
            <RelativeLayout
                android:id="@+id/sender_info_bubble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_background_grey"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/sender_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sender Name"
                    android:textColor="@android:color/white"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/sender_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="sender.email@example.com"
                    android:textColor="@android:color/white"
                    android:autoLink="email"
                    android:textColorLink="#FFF"
                    android:layout_below="@id/sender_name"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="4dp" /> </RelativeLayout>

            <!-- Main Message Bubble -->
            <TextView
                android:id="@+id/message_bubble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/sender_info_bubble"
                android:background="@drawable/rounded_background_grey"
                android:padding="12dp"
                android:text="@string/long_message_text"
                android:textColor="@android:color/white"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="8dp"/>

            <!-- Timestamp -->
            <TextView
                android:id="@+id/timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/message_bubble"
                android:text="@string/sent_timestamp"
                android:textStyle="bold"
                android:textColor="#5A5A5A"
                android:textSize="15sp" />

        </RelativeLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <RelativeLayout
        android:id="@+id/bottom_nav_layout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bottom_nav_background"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bottom_nav_background"
            android:elevation="4dp">

            <FrameLayout
                android:id="@+id/nav_person_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:background="@drawable/music_note_selected_background"
                    android:contentDescription="@string/music_icon"
                    android:padding="8dp"
                    app:tint="@color/white"
                    android:src="@drawable/ic_person" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_add_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/add_icon"
                    android:padding="8dp"
                    android:src="@drawable/ic_add_circle" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_music_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/music_icon"
                    android:padding="8dp"
                    android:src="@drawable/ic_music_note" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_group_button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/group_icon"
                    android:padding="8dp"
                    android:src="@drawable/medical_assistance" />
            </FrameLayout>
        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>
