<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Shape with Color, Corners, and Stroke -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6A475A" />
            <corners android:radius="8dp" /> <!-- Adjust corner radius as needed -->
            <stroke android:width="1dp" android:color="#6A475A" />
        </shape>
    </item>

    <!-- Dropdown Arrow Icon -->
    <item
        android:drawable="@drawable/ic_arrow_down"
        android:gravity="end|center_vertical"
        android:end="12dp"> <!-- Padding from the right edge -->
    </item>
</layer-list>
