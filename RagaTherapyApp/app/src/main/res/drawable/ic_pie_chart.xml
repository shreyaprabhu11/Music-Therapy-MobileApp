<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Group to apply a horizontal flip -->
    <group
        android:scaleX="-1"
        android:pivotX="12">

        <!-- This path draws a 270-degree arc to form the main body of the pie chart -->
        <path
            android:fillColor="@color/black"
            android:pathData="M12,2 a10,10 0 1 1 -10,10 h10 v-10 z" />

    </group>

</vector>

