<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Card background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/> <!-- card background color -->
        </shape>
    </item>

    <!-- Bottom border -->
    <item android:bottom="0dp" android:left="0dp" android:right="0dp" android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:height="4dp"/> <!-- thickness of bottom border -->
            <solid android:color="#000000"/> <!-- black border -->
        </shape>
    </item>

</layer-list>
